{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@app/shared": ["libs/shared/src"],
      "@app/shared/*": ["libs/shared/src/*"],
      "@app/detection-engine": ["libs/detection-engine/src"],
      "@app/detection-engine/*": ["libs/detection-engine/src/*"],
      "@app/semantic-cache": ["libs/semantic-cache/src"],
      "@app/semantic-cache/*": ["libs/semantic-cache/src/*"],
      "@app/ai-proxy": ["libs/ai-proxy/src"],
      "@app/ai-proxy/*": ["libs/ai-proxy/src/*"],
      "@app/logging": ["libs/logging/src"],
      "@app/logging/*": ["libs/logging/src/*"],
      "@app/metrics": ["libs/metrics/src"],
      "@app/metrics/*": ["libs/metrics/src/*"]
    }
  }
}
