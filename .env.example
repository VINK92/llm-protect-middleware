# ============================================================================
# LLM-Protect Middleware - Environment Configuration
# Copy this file to .env and adjust values for your environment
# ============================================================================

# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Redis (cache, rate-limit, vector store) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- AI Backend (Ollama or mock) ---
# AI_BACKEND: "ollama" | "mock"
AI_BACKEND=mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Detection Engine: Stage 1a (Content-Length) ---
STAGE_CONTENT_LENGTH_ENABLED=true
STAGE_CONTENT_LENGTH_MAX_BYTES=1048576

# --- Detection Engine: Stage 1b (Rate Limit) ---
STAGE_RATE_LIMIT_ENABLED=true
STAGE_RATE_LIMIT_WINDOW_SEC=60
STAGE_RATE_LIMIT_MAX_REQUESTS=100

# --- Detection Engine: Stage 2 (SHA-256 Exact Cache) ---
STAGE_EXACT_CACHE_ENABLED=true
STAGE_EXACT_CACHE_TTL_SEC=3600

# --- Detection Engine: Stage 3 (Shannon Entropy) ---
STAGE_ENTROPY_ENABLED=true
# Block if entropy > MAX (random garbage) or < MIN (repetitive)
STAGE_ENTROPY_MIN=1.5
STAGE_ENTROPY_MAX=6.0
STAGE_ENTROPY_MIN_LENGTH=20

# --- Detection Engine: Stage 4 (Token Limit) ---
STAGE_TOKEN_LIMIT_ENABLED=true
STAGE_TOKEN_LIMIT_MAX_TOKENS=8000

# --- Detection Engine: Stage 5 (Semantic Cache / Embedding) ---
STAGE_SEMANTIC_CACHE_ENABLED=true
STAGE_SEMANTIC_CACHE_THRESHOLD=0.95
STAGE_SEMANTIC_CACHE_TTL_SEC=3600
# EMBEDDING_PROVIDER: "mock" | "onnx"
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_PATH=./models/all-MiniLM-L6-v2.onnx
EMBEDDING_DIM=384

# --- Adaptive Rate Limiter (token-budget) ---
RL_TOKEN_BUDGET_PER_MIN=10000
RL_ADAPTIVE_ENABLED=true
RL_CPU_THRESHOLD=80

# --- Risk Score weights ---
RISK_WEIGHT_TOKEN_COUNT=0.3
RISK_WEIGHT_FREQUENCY=0.3
RISK_WEIGHT_REPETITION=0.2
RISK_WEIGHT_ENTROPY=0.2
