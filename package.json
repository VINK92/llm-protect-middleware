{
  "name": "llm-protect-middleware",
  "version": "0.1.0",
  "description": "Middleware system to protect AI APIs from Model Denial of Service attacks (cascade filtering architecture)",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build gateway",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start gateway",
    "start:dev": "nest start gateway --watch",
    "start:debug": "nest start gateway --debug --watch",
    "start:prod": "node dist/apps/gateway/apps/gateway/src/main",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/helmet": "^12.0.0",
    "@fastify/static": "^7.0.4",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@willsoto/nestjs-prometheus": "^6.0.1",
    "axios": "^1.7.7",
    "cache-manager": "^5.7.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "js-tiktoken": "^1.0.14",
    "nestjs-pino": "^4.1.0",
    "onnxruntime-node": "^1.27.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "watchman": false,
    "moduleNameMapper": {
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1",
      "^@app/detection-engine(|/.*)$": "<rootDir>/libs/detection-engine/src/$1",
      "^@app/semantic-cache(|/.*)$": "<rootDir>/libs/semantic-cache/src/$1",
      "^@app/ai-proxy(|/.*)$": "<rootDir>/libs/ai-proxy/src/$1",
      "^@app/logging(|/.*)$": "<rootDir>/libs/logging/src/$1",
      "^@app/metrics(|/.*)$": "<rootDir>/libs/metrics/src/$1"
    }
  }
}
